
{
  "extends": [
    "development"
  ],
  "hints": {
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "backdrop-filter",
          "scrollbar-width",
          "scrollbar-width: none"
        ]
      }
    ],
    "disown-opener": "on",
    "axe/forms": [
      "default",
      {
        "select-name": "on"
      }
    ],
    "css-prefix-order": "off",
    "compat-api/html": [
      "default",
      {
        "ignore": [
          "meta[name=theme-color]"
        ]
      }
    ],
    "no-inline-styles": "off"
  }
}